# Production – www.clever-neuwagen.de (IONOS VPS)
NODE_ENV=production
PORT=3001
HOST=127.0.0.1
PUBLIC_URL=https://www.clever-neuwagen.de

# Berater-Pilot: Share-Links, Leads, Kundenakten (JSON, serverseitig)
# VPS: persistent außerhalb des Deploy-Verzeichnisses (siehe DEPLOY.md)
PILOT_DATA_DIR=/var/lib/clever-neuwagen/data

# Google Maps – Frontend (Autocomplete / Karten, nur VITE_-Variablen)
VITE_MAPS_PROVIDER=google
VITE_GOOGLE_MAPS_API_KEY=

# Google Places – echte Bewertungen (Server-only, nie im Frontend)
GOOGLE_PLACES_API_KEY=

# E-Mail (zentraler Versand über info@clever-neuwagen.de)
# mock | resend | smtp
MAIL_TRANSPORT=mock
RESEND_API_KEY=
# Optional Client-Hinweis (Anzeige)
VITE_MAIL_TRANSPORT=mock
VITE_EMAIL_PROVIDER=mock
VITE_RESEND_API_KEY=
VITE_EMAIL_FROM=info@clever-neuwagen.de

# Sprint 5 – Dokumenten-Tresor (optional, ≥32 Zeichen)
DOCUMENT_ENCRYPTION_KEY=
DOCUMENT_PURGE_INTERVAL_MS=900000

# Pilot LIVE – Autohaus Trinkle, nur Kia, echte Leads (Build-Zeit)
# Dev: npm run dev:pilot  oder  .env.local mit VITE_PILOT_LIVE=true
VITE_PILOT_LIVE=false
VITE_PILOT_DEALER_ID=autohaus-trinkle
VITE_PILOT_KIA_ONLY=true

# Interne Testumgebung (passwortgeschützt, nicht öffentlich)
# Dev: npm run dev:test  |  Build: npm run build:test
# Server optional zusätzlich: INTERNAL_TEST_ENV=true (robots.txt / sitemap)
VITE_INTERNAL_TEST_ENV=false

# OpenAI Berater – nur Server (nie VITE_, nie ins Frontend committen)
# Dev: in .env.local setzen, Server lädt beim Start via server/loadEnv.js
ADVISOR_USE_OPENAI=false
OPENAI_API_KEY=
# OPENAI_QUERY_MODEL=gpt-4o-mini

# Clever AI Conversation Engine (Responses API, server-only)
CLEVER_AI_CONVERSATION_ENABLED=false
# OPENAI_CLEVER_MODEL=gpt-5.6-luna
# CLEVER_AI_TIMEOUT_MS=25000
# Optional: Modellliste für clever:eval:compare (kommagetrennt)
# CLEVER_EVAL_MODELS=gpt-5.6-luna,gpt-4o-mini,gpt-5.6-terra

# Clever Shared Intelligence – Lexikon + Verkäufer-Copilot (Standard: aus)
CLEVER_LEXICON_AI_ENABLED=false
CLEVER_SELLER_COPILOT_ENABLED=false
# CLEVER_OFFICIAL_WEB_SEARCH_ENABLED=false
# CLEVER_AI_ESCALATION_ENABLED=false
# OPENAI_CLEVER_ESCALATION_MODEL=gpt-5.6-terra
# VITE_CLEVER_AI_CONVERSATION_ENABLED=false
# VITE_CLEVER_LEXICON_AI_ENABLED=false
# VITE_CLEVER_SELLER_COPILOT_ENABLED=false
