{
  "name": "clever-neuwagen",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,vite -c blue,green \"npm run dev:server\" \"wait-on http-get://127.0.0.1:3001/health && npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "start:prod": "cross-env NODE_ENV=production node server/index.js",
    "deploy:check": "npm run build && node --check server/index.js",
    "lint": "eslint .",
    "test:intent": "node src/services/search/searchIntentParser.test.js",
    "test:typo": "node src/services/search/typoTolerant.test.js",
    "test:sprint27": "node src/services/search/sprint27.test.js",
    "test:chips": "node src/services/search/chipConfig.test.js",
    "test:model-intent": "node src/services/search/modelIntent.test.js",
    "test:brand-filter": "node src/logic/brandResultsFilter.test.js",
    "test:search-conflict": "node src/services/search/searchConflictHint.test.js",
    "test:brand-exclusion": "node src/logic/brandExclusionConflictView.test.js",
    "test:vehicle-detail-pricing": "node src/logic/vehicleDetailPricing.test.js",
    "test:pricing-resolver": "node src/services/pricing/pricingResolver.test.js",
    "test:wish-magic": "node src/services/configurator/wishMagicService.test.js",
    "test:clever-quote": "node src/services/cleverQuote/cleverQuoteService.test.js",
    "test:smart-sales": "node src/services/sales/salesAdvisorService.test.js",
    "test:kia-partner": "node src/data/kia/kiaPartnerHub.test.js",
    "test:kia-pricelist": "node src/data/kia/kiaOfficialPriceList.test.js",
    "test:kia-pdf": "node src/data/kia/kiaPriceListRegistry.test.js",
    "test:kia-sportage": "node src/data/kia/sportagePdfCanonical.test.js",
    "test:kia-ocr": "node src/data/kia/ocrPdfCanonical.test.js",
    "parse:kia-pdf": "python scripts/parse-kia-pricelists.py",
    "extract:kia-images": "python scripts/extract-kia-pdf-images.py",
    "test:conversation": "node src/services/sales/conversationMode.test.js",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "pdf-parse": "^2.4.5",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
