{
  "name": "clever-neuwagen",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,vite -c blue,green \"npm run dev:server\" \"wait-on http-get://127.0.0.1:3001/health && npm run dev:client\"",
    "dev:pilot": "cross-env VITE_PILOT_LIVE=true VITE_PILOT_DEALER_ID=autohaus-trinkle VITE_PILOT_KIA_ONLY=true concurrently -k -n server,vite -c blue,green \"npm run dev:server\" \"wait-on http-get://127.0.0.1:3001/health && npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "start:prod": "cross-env NODE_ENV=production node server/index.js",
    "deploy:check": "npm run build && node --check server/index.js",
    "lint": "eslint .",
    "test:intent": "node src/services/search/searchIntentParser.test.js",
    "test:feature-rules": "node src/services/search/vehicleFeatureRuleEngine.test.js",
    "test:advisor-alternatives": "node src/services/search/advisorSearchAlternatives.test.js",
    "test:typo": "node src/services/search/typoTolerant.test.js",
    "test:sprint27": "node src/services/search/sprint27.test.js",
    "test:chips": "node src/services/search/chipConfig.test.js",
    "test:model-intent": "node src/services/search/modelIntent.test.js",
    "test:brand-filter": "node src/logic/brandResultsFilter.test.js",
    "test:search-conflict": "node src/services/search/searchConflictHint.test.js",
    "test:brand-exclusion": "node src/logic/brandExclusionConflictView.test.js",
    "test:vehicle-detail-pricing": "node src/logic/vehicleDetailPricing.test.js",
    "test:pricing-resolver": "node src/services/pricing/pricingResolver.test.js",
    "test:wish-magic": "node src/services/configurator/wishMagicService.test.js",
    "test:clever-quote": "node src/services/cleverQuote/cleverQuoteService.test.js",
    "test:smart-sales": "node src/services/sales/salesAdvisorService.test.js",
    "test:advisor-api": "node server/advisorEngine.test.js",
    "test:share-lead": "node src/services/advisor/sharePilotLead.test.js",
    "test:vehicle-detail-api": "node src/services/advisor/advisorVehicleClient.test.js",
    "test:customer-records": "node server/customerRecordsStore.test.js",
    "test:json-store": "node server/jsonStore.test.js",
    "test:pilot-flow": "node server/pilotFlowE2e.test.js",
    "test:sprint34-chips": "node src/services/sales/sprint34WishChipMatrix.test.js",
    "test:sprint34-perf": "node src/services/sales/smartSalesPerformance.test.js",
    "test:sprint34": "npm run test:sprint34-chips && npm run test:sprint34-perf",
    "test:kia-partner": "node src/data/kia/kiaPartnerHub.test.js",
    "test:kia-pricelist": "node src/data/kia/kiaOfficialPriceList.test.js",
    "test:kia-pdf": "node src/data/kia/kiaPriceListRegistry.test.js",
    "test:kia-sportage": "node src/data/kia/sportagePdfCanonical.test.js",
    "test:kia-ocr": "node src/data/kia/ocrPdfCanonical.test.js",
    "parse:kia-pdf": "python scripts/parse-kia-pricelists.py",
    "extract:kia-images": "node scripts/extract-kia-pdf-images.mjs",
    "extract:kia-images:py": "python scripts/extract-kia-pdf-images.py",
    "test:conversation": "node src/services/sales/conversationMode.test.js",
    "test:dealer-brief": "node src/logic/dealerInquiryBrief.test.js",
    "test:mvp-discovery": "node src/logic/mvpDiscoveryPricing.test.js",
    "test:kia-mvp": "node src/logic/kiaEv3SportageMvp.test.js",
    "test:clever-data": "node src/services/cleverData/cleverDataEngine.test.js",
    "test:kia-clever-records": "node src/data/clever/kiaCleverRecords.test.js",
    "test:kia-ev4": "node src/logic/kiaEv4Registry.test.js",
    "test:kia-picanto": "node src/logic/kiaPicantoRegistry.test.js",
    "test:kia-trinkle-stock": "node src/data/kia/kiaTrinkleStock.test.js",
    "test:kia-registry": "npm run test:kia-mvp && npm run test:kia-ev4 && npm run test:kia-picanto && npm run test:kia-partner && npm run test:kia-pdf && npm run test:kia-ocr",
    "test:vd-stream": "node src/logic/vehicleDetailStream.test.js",
    "test:feature-resolver": "node src/services/configuration/featureResolver.test.js",
    "test:inquiry-flow": "node src/logic/inquiryFlowMvp.test.js",
    "test:whatsapp-brief": "node src/logic/whatsappBriefMessages.test.js",
    "test:feinschliff50": "node src/services/search/feinschliff50Search.test.js",
    "test:feinschliff": "npm run test:dealer-brief && npm run test:whatsapp-brief && npm run test:feinschliff50 && npm run test:conversation && npm run test:smart-sales",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "clever-neuwagen": "file:",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@napi-rs/canvas": "^1.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^4.10.38",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
